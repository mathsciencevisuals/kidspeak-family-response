NODE_ENV=development
PORT=8080
REGION=us-central1

# Storage
STORAGE_PROVIDER=firebase
ENABLE_REDIS=false
GOOGLE_CLOUD_PROJECT=your-gcp-project
FIRESTORE_DATABASE_ID=(default)
AUDIO_BUCKET_NAME=kidspeak-temp-audio
AUDIO_RETENTION_DAYS=7
STORE_RAW_AUDIO=false

# Auth and roles
REQUIRE_AUTH=false
FIREBASE_AUTH_PROJECT_ID=your-gcp-project

# Cost guardrails
MAX_AUDIO_DURATION_SECONDS=300
MAX_AUDIO_FILE_MB=25
DAILY_ANALYSIS_LIMIT_PER_FAMILY=20
DAILY_THERAPIST_EXPORT_LIMIT=20
DAILY_AI_PERSONALIZATION_LIMIT=10
DAILY_AI_COST_LIMIT_SOFT=5
DISABLE_REAL_AI=true
USE_MOCK_TRANSCRIPTION=true
USE_REALTIME_STT=false
USE_GEMINI_ANALYSIS=false
USE_RULE_BASED_ANALYSIS=true
ALLOW_AUDIO_UPLOAD=true
ENABLE_LIVE_COACH=false
ENABLE_THERAPIST_DASHBOARD=true
ENABLE_REGIONAL_LANGUAGES=true
ENABLE_TRANSCRIPT_UPLOAD=true
LOG_LEVEL=info
LIVE_COACH_AUDIO_ENABLED=false
LIVE_COACH_CHUNK_SECONDS=15
LIVE_COACH_DAILY_SESSION_LIMIT=5

# Optional Gemini / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=false
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-flash

# Local development fallback
REDIS_URL=
